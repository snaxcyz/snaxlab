---
import Link from '@/components/Link.astro'
import AvatarComponent from '@/components/ui/avatar'
import { cn } from '@/lib/utils'
import type { SocialLink } from '@/types'
import type { CollectionEntry } from 'astro:content'
import SocialIcons from './SocialIcons.astro'

interface Props {
  author: CollectionEntry<'author'>
}

// Destructure from Astro.props
const { author } = Astro.props

// If your collection has flat fields (no .data):
const { name, avatar, bio, pronouns, website, github, twitter, linkedin, mail, slug } = author

// Current URL
const currentPath = Astro.url.pathname
// Use slug if 'id' doesn't exist
const isAuthorPage = currentPath === `/authors/${slug}`

// Build social links array
const socialLinks: SocialLink[] = [
  website && { href: website, label: 'Website' },
  github && { href: github, label: 'GitHub' },
  twitter && { href: twitter, label: 'Twitter' },
  linkedin && { href: linkedin, label: 'LinkedIn' },
  mail && { href: `mailto:${mail}`, label: 'Email' },
].filter(Boolean) as SocialLink[]
---
