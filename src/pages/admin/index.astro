---
const pageTitle = 'SnaxLab Admin'
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{pageTitle}</title>
    <script>
      const savedTheme = localStorage.getItem('snaxlab-admin-theme')
      const prefersLight = window.matchMedia(
        '(prefers-color-scheme: light)',
      ).matches
      document.documentElement.dataset.theme =
        savedTheme || (prefersLight ? 'light' : 'dark')
    </script>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <div class="brand">
          <div class="brand-mark">
            <img src="/static/logo.svg" alt="SnaxLab logo" />
          </div>
          <div>
            <p class="eyebrow">SnaxLab</p>
            <h1>Admin</h1>
          </div>
        </div>

        <nav class="nav" aria-label="Admin sections">
          <a class="nav-item active" href="#editor">Editor</a>
          <a class="nav-item" href="#preview">Preview</a>
          <a class="nav-item" href="#publish">Publish</a>
        </nav>

        <div class="status-card">
          <span class="pulse"></span>
          <div>
            <strong>Static CMS mode</strong>
            <p>
              Creates MDX posts in GitHub through a private Netlify Function.
            </p>
          </div>
        </div>
      </aside>

      <main class="workspace">
        <section class="hero">
          <div>
            <p class="eyebrow">for</p>
            <h2>Create and publish "SnaxLab" posts.</h2>
          </div>
          <div class="hero-actions">
            <button
              class="theme-toggle"
              id="themeToggle"
              type="button"
              aria-label="Switch theme"
            >
              <span class="theme-label">Theme</span>
              <span class="theme-switch" aria-hidden="true"></span>
              <span class="theme-value">Light</span>
            </button>
            <button class="ghost" id="loadDraftBtn" type="button"
              >Load draft</button
            >
            <button class="danger" id="clearBtn" type="button">Clear</button>
          </div>
        </section>

        <section class="grid">
          <form class="panel editor" id="postForm">
            <div class="panel-head" id="editor">
              <div>
                <p class="eyebrow">Article metadata</p>
                <h3>New post</h3>
              </div>
              <span class="badge" id="saveState">Autosave ready</span>
            </div>

            <label>
              <span>Admin password</span>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
              />
            </label>

            <div class="two-cols">
              <label>
                <span>Language</span>
                <select id="lang" name="lang" required>
                  <option value="uz">Uzbek</option>
                  <option value="en">English</option>
                </select>
              </label>

              <label>
                <span>Status</span>
                <select id="draft" name="draft">
                  <option value="false">Publish now</option>
                  <option value="true">Save as draft</option>
                </select>
              </label>
            </div>

            <label>
              <span>Title</span>
              <input id="title" name="title" maxlength="120" required />
            </label>

            <label>
              <span>Description</span>
              <textarea
                id="description"
                name="description"
                class="small-textarea"
                placeholder="Short summary for blog cards "
                maxlength="240"
                required></textarea>
            </label>

            <div class="two-cols">
              <label>
                <span>Slug</span>
                <input id="slug" name="slug" placeholder="auto-generated" />
              </label>

              <label>
                <span>Translation ID</span>
                <input
                  id="translationId"
                  name="translationId"
                  placeholder="same-id-for-uz-and-en"
                />
              </label>
            </div>

            <label>
              <span>Tags</span>
              <input id="tags" name="tags" placeholder="coding, astro, linux" />
            </label>

            <label>
              <span>Authors</span>
              <input
                id="authors"
                name="authors"
                value="enscribe"
                placeholder="enscribe"
              />
            </label>

            <label>
              <span>Article body</span>
              <textarea
                id="body"
                name="body"
                class="body-editor"
                placeholder="# Start writing here..."
                required></textarea>
            </label>

            <div class="toolbar" id="publish">
              <button class="primary" type="submit">Publish to SnaxLab</button>
              <button class="ghost" id="copyMdxBtn" type="button"
                >Copy MDX</button
              >
            </div>

            <p class="message" id="message" role="status"></p>
          </form>

          <section class="panel preview" id="preview">
            <div class="panel-head">
              <div>
                <p class="eyebrow">Live output</p>
                <h3>Preview</h3>
              </div>
              <span class="badge" id="wordCount">0 words</span>
            </div>

            <div class="preview-card">
              <div class="preview-meta">
                <span id="previewLang">UZ</span>
                <span id="previewDate"></span>
              </div>
              <h4 id="previewTitle">title will appear here</h4>
              <p id="previewDescription">
                description preview will appear here.
              </p>
              <div class="tag-list" id="previewTags"></div>
            </div>

            <div class="mdx-box">
              <div class="mdx-head">
                <span>Generated MDX</span>
                <code id="fileName">src/content/blog/post.mdx</code>
              </div>
              <pre id="mdxPreview"></pre>
            </div>
          </section>
        </section>
      </main>
    </div>

    <script>
      // @ts-nocheck
      const form = document.querySelector('#postForm')
      const fields = {
        password: document.querySelector('#password'),
        title: document.querySelector('#title'),
        description: document.querySelector('#description'),
        lang: document.querySelector('#lang'),
        draft: document.querySelector('#draft'),
        slug: document.querySelector('#slug'),
        translationId: document.querySelector('#translationId'),
        tags: document.querySelector('#tags'),
        authors: document.querySelector('#authors'),
        body: document.querySelector('#body'),
      }

      const message = document.querySelector('#message')
      const saveState = document.querySelector('#saveState')
      const previewTitle = document.querySelector('#previewTitle')
      const previewDescription = document.querySelector('#previewDescription')
      const previewTags = document.querySelector('#previewTags')
      const previewLang = document.querySelector('#previewLang')
      const previewDate = document.querySelector('#previewDate')
      const wordCount = document.querySelector('#wordCount')
      const mdxPreview = document.querySelector('#mdxPreview')
      const fileName = document.querySelector('#fileName')
      const clearBtn = document.querySelector('#clearBtn')
      const loadDraftBtn = document.querySelector('#loadDraftBtn')
      const copyMdxBtn = document.querySelector('#copyMdxBtn')
      const themeToggle = document.querySelector('#themeToggle')
      const themeValue = themeToggle.querySelector('.theme-value')

      const STORAGE_KEY = 'snaxlab-admin-draft-v1'
      const THEME_KEY = 'snaxlab-admin-theme'

      function setTheme(theme) {
        document.documentElement.dataset.theme = theme
        localStorage.setItem(THEME_KEY, theme)
        themeValue.textContent = theme === 'dark' ? 'Light' : 'Dark'
        themeToggle.setAttribute('aria-pressed', theme === 'light')
        themeToggle.setAttribute(
          'aria-label',
          `Switch to ${theme === 'dark' ? 'light' : 'dark'} mode`,
        )
      }

      function slugify(value) {
        return value
          .toLowerCase()
          .trim()
          .replace(/['\u2019]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '')
      }

      function splitList(value) {
        return value
          .split(',')
          .map((item) => item.trim())
          .filter(Boolean)
      }

      function yamlString(value) {
        return JSON.stringify(String(value || ''))
      }

      function today() {
        return new Date().toISOString().slice(0, 10)
      }

      function getData() {
        const title = fields.title.value.trim()
        const autoSlug = slugify(title || 'untitled-post')
        const slug = slugify(fields.slug.value || autoSlug)
        const translationId = slugify(fields.translationId.value || slug)

        return {
          password: fields.password.value,
          title,
          description: fields.description.value.trim(),
          lang: fields.lang.value,
          draft: fields.draft.value === 'true',
          slug,
          translationId,
          tags: splitList(fields.tags.value),
          authors: splitList(fields.authors.value || 'enscribe'),
          body: fields.body.value.trim(),
        }
      }

      function makeMdx(data) {
        const draftLine = data.draft ? 'draft: true\n' : ''
        return `---
title: ${yamlString(data.title)}
description: ${yamlString(data.description)}
date: ${today()}
lang: ${yamlString(data.lang)}
translationId: ${yamlString(data.translationId)}
tags: ${JSON.stringify(data.tags)}
authors: ${JSON.stringify(data.authors)}
${draftLine}---

${data.body}
`
      }

      function updatePreview() {
        const data = getData()
        const mdx = makeMdx(data)

        previewTitle.textContent = data.title || 'Your title will appear here'
        previewDescription.textContent =
          data.description || 'Your description preview will appear here.'
        previewLang.textContent = data.lang.toUpperCase()
        previewDate.textContent = today()
        fileName.textContent = `src/content/blog/${data.slug}-${data.lang}.mdx`
        mdxPreview.textContent = mdx

        const words = data.body
          ? data.body.split(/\s+/).filter(Boolean).length
          : 0
        wordCount.textContent = `${words} word${words === 1 ? '' : 's'}`

        previewTags.innerHTML = ''
        ;(data.tags.length ? data.tags : ['no tags yet']).forEach((tag) => {
          const el = document.createElement('span')
          el.textContent = tag
          previewTags.appendChild(el)
        })
      }

      function saveDraft() {
        const data = getData()
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data))
        saveState.textContent = 'Autosaved'
        window.setTimeout(() => (saveState.textContent = 'Autosave ready'), 900)
      }

      function loadDraft() {
        const raw = localStorage.getItem(STORAGE_KEY)
        if (!raw) {
          message.textContent = 'No saved draft found.'
          return
        }

        const data = JSON.parse(raw)
        Object.entries(data).forEach(([key, value]) => {
          if (!fields[key] || key === 'password') return
          fields[key].value = Array.isArray(value)
            ? value.join(', ')
            : String(value)
        })
        message.textContent = 'Draft loaded.'
        updatePreview()
      }

      Object.values(fields).forEach((field) => {
        field.addEventListener('input', () => {
          if (field === fields.title && !fields.slug.dataset.touched) {
            fields.slug.value = slugify(fields.title.value)
            fields.translationId.value = fields.slug.value
          }
          updatePreview()
          saveDraft()
        })
      })

      fields.slug.addEventListener('input', () => {
        fields.slug.dataset.touched = 'true'
      })

      clearBtn.addEventListener('click', () => {
        form.reset()
        fields.authors.value = 'enscribe'
        fields.slug.dataset.touched = ''
        localStorage.removeItem(STORAGE_KEY)
        message.textContent = 'Editor cleared.'
        updatePreview()
      })

      loadDraftBtn.addEventListener('click', loadDraft)

      copyMdxBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(makeMdx(getData()))
          message.textContent = 'MDX copied to clipboard.'
        } catch {
          message.textContent =
            'Clipboard access is unavailable in this browser.'
        }
      })

      themeToggle.addEventListener('click', () => {
        setTheme(
          document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark',
        )
      })

      form.addEventListener('submit', async (event) => {
        event.preventDefault()
        message.textContent = 'Publishing...'
        form.classList.add('is-loading')
        form
          .querySelectorAll('button, input, select, textarea')
          .forEach((control) => (control.disabled = true))

        try {
          const res = await fetch('/.netlify/functions/create-post', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getData()),
          })

          const result = await res
            .json()
            .catch(() => ({ error: 'Server returned an invalid response.' }))

          if (!res.ok) {
            throw new Error(result.error || 'Publish failed')
          }

          message.innerHTML = `Published successfully: <a href="${result.commitUrl}" target="_blank" rel="noreferrer">view commit</a>`
          localStorage.removeItem(STORAGE_KEY)
        } catch (error) {
          message.textContent = error.message
        } finally {
          form.classList.remove('is-loading')
          form
            .querySelectorAll('button, input, select, textarea')
            .forEach((control) => (control.disabled = false))
        }
      })

      previewDate.textContent = today()
      setTheme(document.documentElement.dataset.theme || 'dark')
      updatePreview()
    </script>

    <style>
      @font-face {
        font-family: 'Geist';
        src: url('/fonts/GeistVF.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Geist Mono';
        src: url('/fonts/GeistMonoVF.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }

      :root {
        color-scheme: dark;
        --bg: #161616;
        --sidebar-bg: #111111;
        --surface: #1d1d1d;
        --surface-soft: #242424;
        --surface-muted: #2d2d2d;
        --field-bg: #151515;
        --field-focus: #1b1b1b;
        --border: #343434;
        --border-strong: #4b4b4b;
        --text: #f4f4f5;
        --muted: #a1a1aa;
        --soft: #d4d4d8;
        --accent: #f4f4f5;
        --accent-hover: #e4e4e7;
        --accent-text: #111111;
        --danger: #f87171;
        --danger-bg: rgba(248, 113, 113, 0.1);
        --success: #34d399;
        --link: #a7f3d0;
        --code: #e5e7eb;
        --shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
        --radius: 8px;
      }

      [data-theme='light'] {
        color-scheme: light;
        --bg: #f6f6f4;
        --sidebar-bg: #ffffff;
        --surface: #fffefd;
        --surface-soft: #f4f4f2;
        --surface-muted: #e9e9e5;
        --field-bg: #fffefd;
        --field-focus: #ffffff;
        --border: #deded8;
        --border-strong: #c9c9c0;
        --text: #1c1917;
        --muted: #78716c;
        --soft: #44403c;
        --accent: #1c1917;
        --accent-hover: #292524;
        --accent-text: #ffffff;
        --danger: #b91c1c;
        --danger-bg: #fff1f2;
        --success: #047857;
        --link: #0f766e;
        --code: #292524;
        --shadow: 0 18px 50px rgba(28, 25, 23, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        overflow-x: hidden;
        background:
          linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.035),
            transparent 260px
          ),
          var(--bg);
        color: var(--text);
        font-family:
          Geist,
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          sans-serif;
        font-size: 15px;
        line-height: 1.5;
      }

      a {
        color: var(--link);
      }

      .shell {
        display: grid;
        grid-template-columns: 272px minmax(0, 1fr);
        min-height: 100vh;
      }

      .sidebar {
        position: sticky;
        top: 0;
        height: 100vh;
        padding: 24px;
        border-right: 1px solid var(--border);
        background: var(--sidebar-bg);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .brand-mark {
        display: grid;
        width: 42px;
        height: 42px;
        place-items: center;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--surface-soft);
      }

      .brand-mark img {
        width: 24px;
        height: 24px;
        display: block;
      }

      .eyebrow {
        margin: 0 0 6px;
        color: var(--muted);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      h4,
      p {
        margin-top: 0;
      }

      h1 {
        margin-bottom: 0;
        font-size: 1rem;
        letter-spacing: 0;
      }

      .nav {
        display: grid;
        gap: 6px;
        margin-top: 34px;
      }

      .nav-item {
        padding: 10px 12px;
        border: 1px solid transparent;
        border-radius: 10px;
        color: var(--soft);
        font-size: 0.94rem;
        font-weight: 650;
        text-decoration: none;
        transition:
          background 180ms ease,
          border-color 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      .nav-item.active,
      .nav-item:hover {
        border-color: var(--border);
        background: var(--surface);
        color: var(--text);
      }

      .nav-item:hover {
        transform: translateX(2px);
      }

      .status-card {
        display: flex;
        gap: 12px;
        margin-top: 34px;
        padding: 14px;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--surface);
        color: var(--soft);
      }

      .status-card p {
        margin: 5px 0 0;
        color: var(--muted);
        font-size: 0.88rem;
        line-height: 1.5;
      }

      .pulse {
        width: 10px;
        height: 10px;
        flex: 0 0 auto;
        margin-top: 5px;
        border-radius: 999px;
        background: var(--success);
        box-shadow: 0 0 0 6px rgba(34, 197, 94, 0.14);
      }

      .workspace {
        width: min(100%, 1480px);
        padding: clamp(18px, 3vw, 34px);
      }

      .hero,
      .panel {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--surface);
        box-shadow: var(--shadow);
        animation: admin-fade-in 420ms ease both;
      }

      .hero {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 24px;
        padding: clamp(22px, 3vw, 32px);
      }

      .hero h2 {
        max-width: 720px;
        margin-bottom: 12px;
        font-size: clamp(1.8rem, 3.6vw, 3.1rem);
        font-weight: 720;
        line-height: 1.05;
        letter-spacing: 0;
      }

      .hero-copy {
        max-width: 680px;
        margin-bottom: 0;
        color: var(--soft);
        line-height: 1.65;
      }

      .hero-actions,
      .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .hero-actions {
        align-items: center;
        justify-content: flex-end;
      }

      .grid {
        display: grid;
        grid-template-columns: minmax(0, 1.12fr) minmax(340px, 0.88fr);
        gap: 20px;
        margin-top: 24px;
        align-items: start;
      }

      .panel {
        padding: clamp(18px, 2vw, 24px);
      }

      .panel-head {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 20px;
      }

      .panel-head h3 {
        margin-bottom: 0;
        font-size: 1.24rem;
        letter-spacing: 0;
      }

      .badge {
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 6px 10px;
        background: var(--surface-soft);
        color: var(--soft);
        font-size: 0.78rem;
        white-space: nowrap;
      }

      form {
        display: grid;
        gap: 14px;
      }

      label {
        display: grid;
        gap: 8px;
        color: var(--soft);
        font-size: 0.9rem;
        font-weight: 680;
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 10px;
        outline: none;
        background: var(--field-bg);
        color: var(--text);
        padding: 12px 13px;
        font: inherit;
        transition:
          border-color 0.2s ease,
          background 0.2s ease,
          box-shadow 0.2s ease;
      }

      input::placeholder,
      textarea::placeholder {
        color: var(--muted);
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: var(--border-strong);
        background: var(--field-focus);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 10%, transparent);
      }

      textarea {
        resize: vertical;
      }

      .small-textarea {
        min-height: 96px;
      }

      .body-editor {
        min-height: 430px;
        font-family:
          Geist Mono,
          ui-monospace,
          SFMono-Regular,
          Menlo,
          Monaco,
          Consolas,
          monospace;
        line-height: 1.7;
      }

      .two-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      button {
        border: 1px solid transparent;
        border-radius: 10px;
        padding: 11px 15px;
        color: var(--text);
        font: inherit;
        font-weight: 700;
        cursor: pointer;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease,
          box-shadow 0.2s ease;
      }

      button:hover {
        transform: translateY(-1px);
      }

      .primary {
        background: var(--accent);
        color: var(--accent-text);
        box-shadow: none;
      }

      .primary:hover {
        background: var(--accent-hover);
      }

      .ghost {
        border: 1px solid var(--border);
        background: var(--surface-soft);
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-width: 132px;
        border: 1px solid var(--border);
        background: var(--surface-soft);
        color: var(--text);
        box-shadow: none;
      }

      .theme-label {
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 720;
      }

      .theme-value {
        min-width: 35px;
        text-align: left;
      }

      .theme-switch {
        position: relative;
        width: 38px;
        height: 22px;
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        background: var(--surface-muted);
        transition:
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .theme-switch::after {
        content: '';
        position: absolute;
        top: 3px;
        left: 3px;
        width: 14px;
        height: 14px;
        border-radius: 999px;
        background: var(--text);
        transition: transform 0.2s ease;
      }

      [data-theme='light'] .theme-switch {
        border-color: var(--border-strong);
        background: var(--surface-muted);
      }

      [data-theme='light'] .theme-switch::after {
        transform: translateX(16px);
        background: var(--text);
      }

      .danger {
        border: 1px solid color-mix(in srgb, var(--danger) 30%, transparent);
        background: var(--danger-bg);
        color: var(--danger);
      }

      .message {
        min-height: 24px;
        margin: 0;
        color: var(--soft);
        font-weight: 700;
      }

      .preview {
        position: sticky;
        top: 24px;
      }

      .preview-card {
        padding: 20px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: var(--surface-soft);
      }

      .preview-meta {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .preview-card h4 {
        margin: 18px 0 10px;
        font-size: 1.36rem;
        line-height: 1.15;
        letter-spacing: 0;
      }

      .preview-card p {
        color: var(--soft);
        line-height: 1.7;
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .tag-list span {
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 6px 10px;
        background: var(--surface);
        color: var(--soft);
        font-size: 0.8rem;
      }

      .mdx-box {
        overflow: hidden;
        margin-top: 18px;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: var(--field-bg);
      }

      .mdx-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 13px 15px;
        border-bottom: 1px solid var(--border);
        color: var(--soft);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .mdx-head code {
        color: var(--link);
        font-size: 0.78rem;
      }

      pre {
        max-height: 600px;
        margin: 0;
        overflow: auto;
        padding: 18px;
        color: var(--code);
        font-size: 0.82rem;
        line-height: 1.65;
        white-space: pre-wrap;
      }

      .is-loading {
        opacity: 0.78;
        pointer-events: none;
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          scroll-behavior: auto !important;
          transition-duration: 0.01ms !important;
        }
      }

      @keyframes admin-fade-in {
        from {
          opacity: 0;
          transform: translateY(8px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 1120px) {
        .shell {
          grid-template-columns: 1fr;
        }

        .sidebar {
          position: static;
          height: auto;
          border-right: 0;
          border-bottom: 1px solid var(--border);
        }

        .nav {
          grid-template-columns: repeat(3, 1fr);
        }

        .grid {
          grid-template-columns: 1fr;
        }

        .preview {
          position: static;
        }
      }

      @media (max-width: 720px) {
        .workspace,
        .sidebar {
          padding: 16px;
        }

        .hero {
          align-items: stretch;
          flex-direction: column;
          padding: 22px;
        }

        .two-cols,
        .nav {
          grid-template-columns: 1fr;
        }

        .panel {
          padding: 18px;
        }

        .panel-head,
        .mdx-head {
          align-items: flex-start;
          flex-direction: column;
        }

        .hero-actions,
        .toolbar {
          display: grid;
          grid-template-columns: 1fr;
        }

        button,
        .theme-toggle {
          width: 100%;
        }

        .theme-toggle {
          justify-content: space-between;
        }
      }

      @media (max-width: 420px) {
        .brand {
          align-items: flex-start;
        }

        .brand-mark {
          width: 44px;
          height: 44px;
        }

        .hero h2 {
          font-size: 2rem;
        }

        .badge,
        .mdx-head code {
          white-space: normal;
          word-break: break-word;
        }
      }
    </style>
  </body>
</html>
